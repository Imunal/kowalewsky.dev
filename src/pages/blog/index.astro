---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const allPosts = await getCollection("blog");
const posts = allPosts.sort((a, b) =>
	a.data.date < b.data.date ? 1 : -1,
);

const formatDate = (iso: string) =>
	new Date(iso).toLocaleDateString("en-GB", {
		day: "numeric",
		month: "long",
		year: "numeric",
	});
---

<Layout
	title="Blog | Juliusz Kowalewski"
	description="Thoughts on software architecture, TypeScript, backend engineering, and the lessons learned building production systems."
	canonical="/blog"
	ogUrl="https://kowalewsky.dev/blog"
>
	<section class="py-12">
		<h1
			class="mb-2 text-3xl font-bold text-black dark:text-white md:text-5xl"
		>
			Blog
		</h1>
		<p class="mb-12 font-mono text-sm text-gray-500 dark:text-gray-400">
			Thoughts on software architecture, TypeScript, and building production
			systems.
		</p>

		<div
			class="flex flex-col divide-y divide-gray-200 dark:divide-gray-800"
		>
			{
				posts.map((post) => (
					<a
						href={`/blog/${post.id}`}
						data-astro-prefetch
						class="group flex flex-col gap-1 py-6 hover:opacity-80 transition-opacity"
					>
						<div class="flex items-start justify-between gap-4">
							<h2 class="font-bold text-black dark:text-white group-hover:underline underline-offset-4">
								{post.data.title}
							</h2>
							<time
								datetime={post.data.date}
								class="shrink-0 font-mono text-xs text-gray-400 dark:text-gray-500 mt-1"
							>
								{formatDate(post.data.date)}
							</time>
						</div>
						<p class="font-mono text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
							{post.data.description}
						</p>
						<div class="mt-2 flex flex-wrap gap-2">
							{post.data.tags.map((tag) => (
								<span class="rounded-md bg-gray-200 dark:bg-gray-800 px-2 py-0.5 font-mono text-xs text-gray-500 dark:text-white">
									{tag}
								</span>
							))}
						</div>
					</a>
				))
			}
		</div>
	</section>
</Layout>
